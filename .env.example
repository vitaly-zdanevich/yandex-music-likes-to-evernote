YANDEX_MUSIC_TOKEN=your-yandex-music-token
EVERNOTE_AUTH_TOKEN=your-evernote-auth-token
# Optional: leave blank to discover it from Evernote UserStore.
# EVERNOTE_NOTE_STORE_URL=https://www.evernote.com/shard/XXX/notestore
# EVERNOTE_USER_STORE_URL=https://www.evernote.com/edam/user
# Evernote notebook GUID or exact notebook name.
# EVERNOTE_NOTEBOOK_GUID=
EVERNOTE_TAGS=yandex-music
STATE_PATH=state.json
DRY_RUN=true
# Set to 0 to disable the per-run cap.
MAX_TRACKS_PER_RUN=30
# Download audio in the highest available quality (no re-encoding) and attach it to each note.
# Lossless FLAC needs a Yandex Plus tier that grants it; otherwise the best lossy stream is used.
# Set to false for metadata-only notes.
BACKUP_AUDIO=true
ENRICH_EXTERNAL_LINKS=true
# Comma-separated service ids. If enabled list is non-empty, only listed services are used.
# ENABLED_EXTERNAL_LINK_SERVICES=
# DISABLED_EXTERNAL_LINK_SERVICES=
# GENIUS_ACCESS_TOKEN=
# ACOUSTID_API_KEY=
SONGLINK_USER_COUNTRY=US
